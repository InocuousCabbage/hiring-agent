# .env.example — copy to .env and fill in values

# LLM — pick ONE method:
# Option A: Anthropic API key (direct API access)
# ANTHROPIC_API_KEY=sk-ant-...
# Option B: Claude CLI (uses your Claude subscription — run `claude login` first)
# (leave ANTHROPIC_API_KEY unset to use CLI)

# Your info (used in cover letter headers)
APPLICANT_NAME=Your Name
APPLICANT_CONTACT=City, ST  ·  you@gmail.com  ·  (555) 000-0000

# Gmail
GMAIL_CREDENTIALS_PATH=config/credentials/credentials.json
GMAIL_TOKEN_PATH=config/credentials/token.json
MY_EMAIL=you@gmail.com

# Alert matching, processed label, and paths are configured in
# config/settings.yaml (gmail.alert_sender, gmail.alert_subject_contains,
# gmail.processed_label). No env-var overrides — settings.yaml is the
# single source of truth.
